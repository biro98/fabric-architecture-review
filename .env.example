# Client tenant ID — the tenant you have user / guest access to.
# Auth runs interactively as YOU (no client secret is used).
TENANT_ID=00000000-0000-0000-0000-000000000000

# Optional: override the public client used for the interactive browser flow.
# Defaults to the Azure CLI client ID (04b07795-8ddb-461a-bbee-02f9e1bf7b46),
# which is pre-consented in every tenant — no app registration required.
# CLIENT_ID=

# Optional: override default scopes
FABRIC_SCOPE=https://api.fabric.microsoft.com/.default
POWERBI_SCOPE=https://analysis.windows.net/powerbi/api/.default

# Engagement metadata (rendered into the report)
CLIENT_NAME=Contoso
ENGAGEMENT_NAME=Fabric Architecture Review
REVIEWER_NAME=
REVIEW_DATE=

# Optional: override the left-side label printed in every PDF page footer.
# Defaults to "<CLIENT_NAME> — <ENGAGEMENT_NAME>".
# FOOTER_LABEL=

# Report branding (optional). Both default to empty / none so NO specific brand
# is rendered. Use them to put your own organization on the generated report.
#   REPORT_BRAND  -> brand / org label shown on the PDF cover eyebrow and the
#                    top-right of every page header. Empty = no brand line.
#   REPORT_LOGO   -> path to a PNG cover logo (any brand). Empty/missing = no
#                    logo. There is no logo shipped with the repo by default.
# REPORT_BRAND=
# REPORT_LOGO=

# Output base directory (defaults to ./output). Set to a per-client folder to
# keep engagements isolated, e.g. OUTPUT_DIR=output/contoso. All three pipeline
# scripts honour this and write raw/, findings_*.json, and the PDF under it.
OUTPUT_DIR=output

# Workspace scope. Comma- or whitespace-separated GUIDs. Leave empty for
# tenant-wide. When set, scanner_api, workspace_inventory, and semantic_models
# filter to these IDs; downstream collectors that read scanner.json
# (pipelines_notebooks, lakehouse_warehouse, git_integration,
# realtime_intelligence) inherit the scope. Tenant-wide collectors
# (tenant_settings, activity_logs, capacity_metrics, gateways,
# deployment_pipelines) still report tenant-level facts.
# WORKSPACE_IDS=

# Activity log lookback in days (max 30 per Fabric Admin API)
ACTIVITY_LOG_DAYS=30

# Opt-in toggles for the two collectors that reach beyond Fabric REST.
# Both default to OFF. With both unset/false, the framework is
# 100% metadata-only over Fabric/Power BI REST (no DAX, no Azure ARM).
#
# CAPACITY_METRICS_APP_INSTALLED=true
#   Enables collectors/capacity_metrics_app.py, which uses Power BI
#   executeQueries (DAX) against the Fabric Capacity Metrics App semantic
#   model. Falsy/unset -> the collector skips and writes a "skipped" marker;
#   no DAX is ever issued.
#
# CAPACITY_AUTO_PAUSE_CONFIGURED=true
#   Enables collectors/azure_capacity_automation.py, which logs into Azure
#   Resource Manager (subscriptions, Automation runbooks, Logic Apps) to
#   verify a Pause/Resume schedule for the Fabric capacity. Falsy/unset ->
#   the collector skips and writes a "skipped" marker; no ARM call is made.
#   Requires `az login` (or a working AzureCliCredential) for the signed-in
#   user; the user needs Reader on the subscription that hosts the
#   automation / Logic App.
#
# CAPACITY_METRICS_APP_INSTALLED=false
# CAPACITY_AUTO_PAUSE_CONFIGURED=false
# AZURE_SUBSCRIPTION_ID=                 # optional: restrict ARM scan to one sub
#
# VERTIPAQ_STATS_READ_DATA=true
#   (Fabric runs only) collectors/vertipaq_stats.py uses semantic-link-labs'
#   VertiPaq Analyzer to capture each model's storage footprint. By default it
#   reads sizes / encoding / data type from storage-engine DMVs (metadata only).
#   Set this to true to ALSO compute exact column cardinality via aggregate
#   COUNT-style DAX (returns distinct counts only, never row values).
# VERTIPAQ_STATS_SKIP=true               # disable the VertiPaq collector entirely

# ---------------------------------------------------------------------------
# Pass/fail threshold overrides (optional)
# ---------------------------------------------------------------------------
# Every numeric pass/fail boundary is defined and documented in
# config/thresholds.yaml. Edit that file to tune the review for a client.
# The variables below let CI / the Fabric pipeline override any single value
# WITHOUT editing the file — precedence is: env var > thresholds.yaml > default.
# Leave them unset to use thresholds.yaml. (Values shown are the defaults.)
#
# Architecture
# ARCH_MONOLITH_THRESHOLD=50         # ARCH-005 max items before "monolithic"
# ARCH_PIPELINE_STALE_DAYS=30        # ARCH-014 stale deployment-pipeline stage
#
# Performance
# PERF_MODEL_SIZE_WARN_MB=2048       # PERF-003 semantic-model size warn band
# PERF_MODEL_SIZE_CRITICAL_MB=8192   # PERF-003 semantic-model size critical band
# PERF_FAIL_RATIO_THRESHOLD=0.2      # PERF-004 refresh-failure ratio to fail
# PERF_STALE_DAYS=30                 # PERF-005 days without a successful refresh
# PERF_LONG_REFRESH_HOURS=2          # PERF-007 avg refresh duration to fail
# PERF_REFRESH_OVERLAP_MIN=2         # PERF-014 overlapping-refresh window (min)
# PERF_THROTTLE_CRITICAL_PCT=100     # PERF-001 throttling critical band
# PERF_THROTTLE_WARN_PCT=70          # PERF-001 throttling warn band
# PERF_JOB_FAIL_RATIO=0.2            # PERF-008/009 job failure ratio to fail
# PERF_JOB_LONG_HOURS=1.0            # PERF-008/009 long-running job hours
#
# Governance
# GOV_SHARE_VOLUME_THRESHOLD=100     # GOV-005 share events in window to fail
#
# Security
# SEC_BROAD_ACCESS_THRESHOLD=10      # SEC-005 max individual principals/workspace
# SEC_GATEWAY_MIN_VERSION=           # SEC-010 absolute min gateway version (empty=off)
#
# Cost
# COST_SMALL_WORKSPACE_THRESHOLD=5   # COST-005 min workspaces on a large (F64+) SKU
